{
	"schemaVersion": 1,
	"id": "potions-n-rituals",
	"version": "${version}",
	"name": "Potions & Rituals",
	"description": "Potions & Rituals (Previous name 'The Alchemist's Touch') reworks Minecraft’s potion system with new effects, early-game ingredients, and advanced alchemical interactions.",
	"authors": [
		"Matibi"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "MIT-License",
	"icon": "assets/potions-n-rituals/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.matibi.potionsnrituals.PotionsNRituals"
		],
		"client": [
			"com.matibi.potionsnrituals.PotionsNRitualsClient"
		],
		"fabric-datagen": [
			"com.matibi.potionsnrituals.PotionsNRitualsDataGenerator"
		],
		"modmenu": [
			"com.matibi.potionsnrituals.config.ModMenuIntegration"
		]
	},
	"mixins": [
		"potions-n-rituals.mixins.json"
	],
	"depends": {
		"fabricloader": ">=${loader_version}",
		"minecraft": "~${minecraft_version}",
		"java": ">=25",
		"fabric-api": "*"
	},
	"suggests": {
		"modmenu": ">=${modmenu_version}",
		"yet-another-config-lib": ">=${yacl_version}"
	}
}